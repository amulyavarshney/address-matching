# Optional JSON config file (merged before env overrides)
# CONFIG_FILE=config.json

# Region & logging
ADDRESS_MATCHING_REGION=US
LOG_LEVEL=INFO

# Geocoding
GEOCODING_USER_AGENT=address-matching-service
GEOCODING_TIMEOUT=10
DISTANCE_THRESHOLD=50.0

# Feature toggles
USE_ML_MODEL=true
USE_GEOSPATIAL=true
# DISABLE_ML_MODEL=1
# DISABLE_GEOSPATIAL=1
# DISABLE_LIBPOSTAL=1

# Rule-based filter thresholds
POSTAL_CODE_THRESHOLD=0.8
STREET_THRESHOLD=0.7
CITY_THRESHOLD=0.8
HOUSE_NUMBER_THRESHOLD=0.8
OVERALL_THRESHOLD=0.7

# Strict matching requirements
REQUIRE_POSTAL_CODE_MATCH=false
REQUIRE_CITY_MATCH=true
REQUIRE_STREET_MATCH=true

# ML model
ML_MODEL_PATH=address_matching_model.pkl

# API
API_HOST=0.0.0.0
API_PORT=8000

# Security — set API_KEY to require X-API-Key on match endpoints
# API_KEY=change-me
# Comma-separated allowed origins (* for local only)
CORS_ORIGINS=*
MAX_ADDRESS_LENGTH=500
MAX_BATCH_SIZE=50
RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=60
# memory (default) or redis for multi-instance
RATE_LIMIT_BACKEND=memory
# REDIS_URL=redis://localhost:6379/0

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=address-matching

# Geocoding provider: nominatim (dev), google, mapbox, or none
GEOCODING_PROVIDER=nominatim
# Shared fallback key (used if provider-specific key unset)
# GEOCODING_API_KEY=
# Google: prefer GOOGLE_MAPS_API_KEY
# GOOGLE_MAPS_API_KEY=
# Mapbox: prefer MAPBOX_ACCESS_TOKEN
# MAPBOX_ACCESS_TOKEN=
# Optional bias for commercial providers
# GEOCODING_REGION=us          # Google region bias (ccTLD)
# GEOCODING_LANGUAGE=en        # Google language
# GEOCODING_COUNTRY=US         # Mapbox country filter (ISO 3166-1 alpha-2)
# GEOCODING_MIN_INTERVAL=0     # seconds between geocode calls (Nominatim default 1.0)

# Logging — set to full only for local debugging (never in production)
# LOG_ADDRESS_PII=full

# Dev-only: train synthetic ML model when no pickle exists (never in production)
# ML_AUTO_TRAIN=false
